# REQUIRED: 32-byte hex-encoded secret for signing JWT tokens
# The server will refuse to start without this.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# REQUIRED: 32-byte hex-encoded key for encrypting access tokens at rest
# The server will refuse to start without this.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Optional: seed an admin account on first start (skips the setup screen)
# Both must be set for the account to be created
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=changeme123

# SQLite database path
# DATABASE_URL=sqlite:uwu-admin.db?mode=rwc

# API listen address
# API_LISTEN=127.0.0.1:3001

# CORS origin — set to your frontend URL in production
# Enables CSRF protection and credentialed cookie support
# CORS_ORIGIN=http://localhost:5173

# Set to false to omit the Secure flag on refresh token cookies
# (needed when running over plain HTTP in development)
# COOKIE_SECURE=false

# Set to true to allow adding homeservers that resolve to private/loopback IPs
# (e.g. localhost, 10.x, 192.168.x). Do NOT enable in production.
# ALLOW_PRIVATE_HOMESERVERS=true

# --- Integration test variables (only needed for `cargo test -- --ignored`) ---
# TEST_HOMESERVER=https://matrix.example.com
# TEST_USERNAME=bot_user
# TEST_PASSWORD=bot_password
# TEST_ROOM_ID=!roomid:example.com
