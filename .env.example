# 32-byte hex-encoded secret for signing JWT tokens
# If unset, a random secret is generated (tokens won't survive restarts)
# Generate with: openssl rand -hex 32
JWT_SECRET=

# 32-byte hex-encoded key for encrypting access tokens at rest
# If unset, a random key is generated (encrypted tokens won't survive restarts)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Optional: seed an admin account on first start (skips the setup screen)
# Both must be set for the account to be created
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=changeme123

# SQLite database path
# DATABASE_URL=sqlite:uwu-admin.db?mode=rwc

# API listen address
# API_LISTEN=127.0.0.1:3001

# CORS origin (omit to use default)
# CORS_ORIGIN=http://localhost:5173
