{
  "name": "uwu-admin-web",
  "version": "0.5.5",
  "private": true,
  "description": "Matrix homeserver admin web interface",
  "repository": {
    "type": "git",
    "url": "https://github.com/PNRxA/uwu-admin.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "oxfmt src/"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/vue-query": "^5.92.9",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "lucide-vue-next": "^0.575.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.8.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "vue": "^3.5.28",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.2",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@intlify/eslint-plugin-vue-i18n": "^4.2.0",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.58.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.10.13",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.2.7",
    "@vue/tsconfig": "^0.8.1",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.46.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.32.0",
    "oxlint": "~1.47.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^4.0.18",
